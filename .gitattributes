# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.dart text eol=lf
*.swift text eol=lf
*.java text eol=lf
*.kt text eol=lf

# C/C++
*.c text eol=lf
*.cc text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf

# Scripts
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Build files
*.cmake text eol=lf
*.mk text eol=lf
*.gn text eol=lf
*.gni text eol=lf

# Config / Data
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.lock text eol=lf

# Markdown / Docs
*.md text eol=lf
*.markdown text eol=lf

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.keystore binary
*.a binary
*.so binary
*.dylib binary
*.dll binary
